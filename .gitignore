# 配置与密钥（含 api_key，绝不入仓）
backend/config.json

# Agent 记忆与角色头像（含真实业务经验 / 角色形象，属本地运行数据，不入公开仓）
memory/*.md
!memory/README.md
icon/

# 内部取数 / 知识库 skill（含内部接口地址与凭证、内部数据表名，绝不公开）
# bilisc-* 一律为内部 skill，整类排除；narya-data 单列。新增内部 skill 无需再改此处。
skills/narya-data/
skills/bilisc-*/

# TestReport：白名单模式——默认忽略整个目录（运行产物含真实内网地址/业务数据/截图，
# 如 qa_results_*、collab_scenario_*、weekly_report_*、shots/ 等，绝不入公开仓），
# 仅反选测试脚本本身入库，以单测保障平台稳定性。新增脚本按 run_*.py 命名即自动纳入。
TestReport/*
!TestReport/run_*.py
!TestReport/cleanup_test_data.py
!TestReport/README.md

# SQLite 数据库（含备份，含真实数据/凭证，绝不入仓）
*.db
*.db.bak*
*.db.bak_*
*.db-journal
*.db-wal
*.bak
*.bak_*

# 记忆回滚备份（本地运行产物，不入仓）
backend/_mem_bak_*/
_mem_bak_*/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Node / 前端
node_modules/
frontend/dist/
.vite/

# 日志与临时
*.log
.reimport_*.json
_tmp_*

# 环境与编辑器
.env
.env.local
.DS_Store
.idea/
.vscode/
